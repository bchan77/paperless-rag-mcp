{
  "name": "paperless-rag-mcp",
  "version": "0.1.0",
  "description": "MCP server combining paperless-mcp with RAG pipeline for document Q&A",
  "main": "dist/index.js",
  "type": "module",
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "node --env-file=.env --import=tsx src/index.ts",
    "watch": "node --env-file=.env --import=tsx --watch src/index.ts",
    "test": "node --experimental-vm-modules node_modules/jest/bin/jest.js",
    "test:watch": "node --experimental-vm-modules node_modules/jest/bin/jest.js --watch"
  },
  "dependencies": {
    "@baruchiro/paperless-mcp": "^0.4.1",
    "@lancedb/lancedb": "^0.27.1",
    "@modelcontextprotocol/sdk": "^1.0.0",
    "@qdrant/js-client-rest": "^1.17.0",
    "openai": "^4.104.0"
  },
  "devDependencies": {
    "@types/jest": "^30.0.0",
    "@types/node": "^22.0.0",
    "jest": "^30.3.0",
    "ts-jest": "^29.4.9",
    "tsx": "^4.0.0",
    "typescript": "^5.0.0"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
