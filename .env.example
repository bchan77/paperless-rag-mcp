# Paperless-ngx configuration (required)
PAPERLESS_URL=http://paperless.homelab.local
PAPERLESS_TOKEN=your-paperless-api-token

# Optional: Qdrant vector database (if using instead of default LanceDB)
# QDRANT_URL=http://qdrant.homelab.local:6333
# QDRANT_COLLECTION=paperless_documents

# Optional: LanceDB storage path (default: ./data/lancedb)
# On WSL, use a Linux-native path to avoid lance-rs path bugs:
# LANCEDB_PATH=/home/<user>/.local/share/paperless-rag-mcp/lancedb

# Embedding provider: "openai" (default) or "ollama" (local, free)
# EMBEDDING_PROVIDER=openai

# OpenAI embeddings (required when EMBEDDING_PROVIDER=openai)
OPENAI_API_KEY=your-openai-api-key

# Ollama local embeddings (used when EMBEDDING_PROVIDER=ollama)
# OLLAMA_URL=http://localhost:11434
#   On WSL with Ollama running on Windows, use the Windows host IP:
#   OLLAMA_URL=http://<windows-host-ip>:11434
#   Find it with: cat /etc/resolv.conf | grep nameserver
#   Also set OLLAMA_HOST=0.0.0.0 in Windows env vars and restart Ollama.
# OLLAMA_EMBED_MODEL=nomic-embed-text
# OLLAMA_MAX_CHARS=16000
#   Max characters per chunk sent to Ollama. Tune based on your model's context window.
#   Safe estimate: num_ctx x 2 (e.g. nomic-embed-text has num_ctx=8192 -> 16000).
#   Check with: ollama show <model> | grep num_ctx
