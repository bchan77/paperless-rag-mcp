# Paperless-ngx configuration
PAPERLESS_URL=http://paperless.homelab.local
PAPERLESS_TOKEN=your-paperless-api-token

# Optional: Qdrant vector database (if using instead of default LanceDB)
# QDRANT_URL=http://qdrant.homelab.local:6333
# QDRANT_COLLECTION=paperless_documents

# Optional: LanceDB storage path (default: ./data/lancedb)
# LANCEDB_PATH=./data/lancedb

# Embedding provider: "openai" (default) or "ollama" (local)
# EMBEDDING_PROVIDER=openai

# OpenAI embeddings (required when EMBEDDING_PROVIDER=openai)
OPENAI_API_KEY=your-openai-api-key

# Ollama local embeddings (used when EMBEDDING_PROVIDER=ollama)
# OLLAMA_URL=http://localhost:11434
# OLLAMA_EMBED_MODEL=nomic-embed-text
# OLLAMA_MAX_CHARS=1000   # Max chars per chunk sent to Ollama (tune based on model's context window)
